# Backend env (FastAPI). Production: configure f Easypanel UI.
# Local dev: copy l `.env`.

APP_ENV=production
APP_NAME=Numapetstore API
PUBLIC_SITE_URL=https://numapet.store
PUBLIC_API_URL=https://api.numapet.store

# Easypanel internal Docker hostname. Local dev (via SSH tunnel): 127.0.0.1:5432.
DATABASE_URL=postgres://numapetstore:numapetstore@numapetstore_database:5432/numapetstore?sslmode=disable

CORS_ORIGINS=https://numapet.store

# Secrets — fill f Easypanel UI ghir, ma t-commitihomch.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
SNAP_PIXEL_ID=
SNAP_AD_ACCOUNT_ID=
SNAP_ACCESS_TOKEN=

# MaxMind GeoIP (GeoLite2 free tier kafi)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_EDITION_IDS=GeoLite2-City
MAXMIND_DB_PATH=/data/geoip/GeoLite2-City.mmdb
GEO_ALLOWED_COUNTRIES=PA

# Admin dashboard (login form on /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Long random string. Generate via: python -c "import secrets;print(secrets.token_urlsafe(48))"
ADMIN_SESSION_SECRET=replace-with-long-random-string
ADMIN_SESSION_MAX_AGE=604800

# VPN / proxy detection (used to filter out fake visits/orders).
# Pick ONE of these (vpnapi.io recommended, free 1000/day):
VPNAPI_KEY=
PROXYCHECK_KEY=
